---
import type { ComponentProps } from 'astro/types';
import AnimatedArrow from '@/components/animated-arrow.astro';
import Button from '@/components/button.astro';
import { cn } from '@/lib/utils';

type Props = Omit<ComponentProps<typeof Button>, 'variant' | 'id'> & {
  fallback?: string;
};

const { fallback = '/', class: className, ...props } = Astro.props;
---

<Button
  id="back-button"
  variant="outline"
  class={cn('group', className)}
  data-fallback={fallback}
  {...props}
>
  <AnimatedArrow direction="left" />
  Back
</Button>

<script>
  import { runOnce } from '@/utils/runtime-registry';
  import navigation from '@/utils/navigation';

  runOnce('back-button:page-load-handler', () => {
    document.addEventListener('astro:page-load', () => {
      const backButton = document.getElementById(
        'back-button',
      ) as HTMLButtonElement | null;

      if (!backButton) return;

      const handleNavigateBack = () => {
        if (navigation.canGoBack()) {
          navigation.back();
        } else {
          navigation.navigate(backButton.dataset.fallback ?? '/');
        }
      };

      backButton.onclick = handleNavigateBack;
    });
  });
</script>
