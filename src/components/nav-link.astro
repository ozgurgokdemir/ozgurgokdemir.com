---
import type { HTMLAttributes } from 'astro/types';
import LinkButton from '@/components/link-button.astro';

type Props = HTMLAttributes<'a'> & {
  id: string;
};

const { id, ...props } = Astro.props;
---

<LinkButton
  variant="ghost"
  size="sm"
  data-nav-link
  data-id={id}
  {...props}
>
  <slot />
</LinkButton>
