---
import '@/global.css';
import { ClientRouter } from 'astro:transitions';

export type BaseLayoutProps = {
  title: string;
  description: string;
  type?: 'website' | 'article' | 'profile';
  image?: string | URL;
  imageAlt?: string;
  canonical?: string | URL;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
};

type Props = BaseLayoutProps;

const {
  title,
  description,
  type = 'website',
  image = '/open-graph-image.png',
  imageAlt = title,
  canonical,
  jsonLd,
} = Astro.props;

const siteURL = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(canonical ?? Astro.url.pathname, siteURL);
canonicalURL.search = '';
canonicalURL.hash = '';

const imageURL = new URL(image, siteURL);
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Özgür Gökdemir" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:image:alt" content={imageAlt} />

    {
      jsonLdItems.map((item) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(item)}
        />
      ))
    }

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml" />

    <link
      rel="preload"
      href="/manrope.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  import hashNavigationData from '@/data/navigation.json';
  import { getValue, runOnce, setValue } from '@/utils/runtime-registry';
  import { initHashNavigation } from '@/utils/hash-navigation';
  import { ScrollAnimations } from '@/utils/scroll-animations';
  import navigation from '@/utils/navigation';

  initHashNavigation(
    hashNavigationData.map(({ pathname, id }) => {
      const url = new URL(pathname, window.location.origin);

      return {
        pathname: url.pathname,
        hash: url.hash,
        sectionId: id,
      };
    }),
  );

  runOnce('base-layout:page-load-handler', () => {
    document.addEventListener('astro:page-load', () => {
      getValue<ScrollAnimations>('scroll-animations:instance')?.destroy();
      setValue('scroll-animations:instance', new ScrollAnimations());
      navigation.syncHistory();
    });
  });
</script>
