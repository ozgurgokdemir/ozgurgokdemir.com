---
import { getCollection } from 'astro:content';
import Icon from '@/components/icon.astro';
import { sortByOrder } from '@/utils/content-collections';
import MainLayout from '@/layouts/main-layout.astro';
import LinkButton from '@/components/link-button.astro';
import ProjectCard from '@/components/project-card.astro';
import FormField from '@/components/form-field.astro';
import FormLabel from '@/components/form-label.astro';
import FormInput from '@/components/form-input.astro';
import FormTextarea from '@/components/form-textarea.astro';
import Button from '@/components/button.astro';
import ContactForm from '@/components/contact-form.astro';
import Technology from '@/components/technology.astro';
import AnimatedArrow from '@/components/animated-arrow.astro';
import ImageShowcase from '@/components/image-showcase.astro';
import { stagger } from '@/utils/stagger';

const featuredProjects = await getCollection(
  'projects',
  ({ data }) => data.featured,
)
  .then(sortByOrder)
  .then((projects) => projects.slice(0, 6));

const technologies = await getCollection('technologies').then(sortByOrder);

const contact = await getCollection('contact').then(sortByOrder);

const heroImages = featuredProjects.map(({ data }) => ({
  src: data.image,
  alt: `${data.title} project preview`,
  title: data.title,
}));

const siteURL = Astro.site ?? new URL(Astro.url.origin);
const homeURL = new URL('/', siteURL).toString();
const emailContact = contact.find(({ id }) => id === 'email');
const sameAs = contact
  .filter(({ id }) => id !== 'email')
  .map(({ data }) => data.url);
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Özgür Gökdemir',
    url: homeURL,
    jobTitle: 'Full-Stack Developer',
    email: emailContact?.data.url,
    sameAs,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Özgür Gökdemir',
    url: homeURL,
    inLanguage: 'en-US',
  },
];
---

<MainLayout
  title="Özgür Gökdemir"
  description="Özgür Gökdemir is a full-stack developer who builds frontend interfaces, backend APIs, SaaS products, e-commerce platforms, and mobile applications."
  type="profile"
  imageAlt="Özgür Gökdemir portfolio preview"
  {jsonLd}
>
  <div class="px-4">
    <section
      id="home"
      class="scroll-mt-header mx-auto flex max-w-360 flex-col gap-16 py-16 md:gap-24 md:py-24"
      data-animate
    >
      <div class="grid items-start gap-6 lg:grid-cols-3 lg:items-end lg:gap-4">
        <h1
          class="scroll-animations-hidden max-w-5xl text-left text-3xl font-semibold tracking-tight md:text-5xl lg:col-span-2"
          data-stagger-index="0"
        >
          I build thoughtful software products from interface to backend.
        </h1>
        <div
          class="scroll-animations-hidden flex items-center justify-start gap-4 lg:justify-end lg:pl-12"
          data-stagger-index="1"
        >
          <LinkButton id="contact-link" href="/#contact">
            <Icon name="heroicons:chat-bubble-left-ellipsis-16-solid" />
            Let's Talk
          </LinkButton>
          <LinkButton href="/projects" variant="outline">
            View my work
          </LinkButton>
        </div>
      </div>
      <ImageShowcase
        images={heroImages}
        priority={true}
        class="scroll-animations-hidden"
        data-stagger-index="2"
      />
    </section>
  </div>
  <div class="px-4">
    <section
      id="about"
      class="scroll-mt-header mx-auto flex max-w-360 flex-col gap-16 py-16 md:py-24"
      data-animate
    >
      <h2
        class="scroll-animations-hidden text-2xl font-semibold md:text-3xl"
        data-stagger-index="0"
      >
        A little about me and the tools behind my work.
      </h2>
      <div class="grid gap-16 md:grid-cols-3 md:gap-4">
        <ul
          class="order-2 grid grid-cols-2 gap-2 md:order-1 md:col-span-2 md:auto-cols-fr md:grid-flow-col md:grid-cols-none md:grid-rows-4 md:self-start"
        >
          {
            technologies.map(({ data }, index) => (
              <li
                class="scroll-animations-hidden"
                data-stagger-index={stagger({
                  default: index + 2,
                  768: index + 1,
                })}
              >
                <Technology
                  label={data.label}
                  category={data.category}
                  icon={data.icon}
                />
              </li>
            ))
          }
        </ul>
        <div
          class="text-muted-foreground scroll-animations-hidden order-1 flex flex-col items-start gap-4 text-lg md:order-2 lg:pl-12"
          data-stagger-index={stagger({
            default: 1,
            768: technologies.length + 1,
          })}
        >
          <p>
            I’m a full-stack developer focused on building thoughtful, practical
            software products. I care about the details that make an interface
            feel polished, and the systems behind it that make a product
            reliable.
          </p>
          <p>
            My work spans frontend interfaces, backend APIs, SaaS products,
            e-commerce platforms, and mobile applications. I enjoy working
            across the product, from shaping user flows and interaction details
            to designing data models, integrations, authentication, and
            deployment.
          </p>
        </div>
      </div>
    </section>
  </div>
  <div class="px-4">
    <section
      id="projects"
      class="scroll-mt-header mx-auto flex max-w-360 flex-col gap-16 py-16 md:py-24"
      data-animate
    >
      <div class="flex flex-col items-start gap-4">
        <h2
          class="scroll-animations-hidden text-2xl font-semibold md:text-3xl"
          data-stagger-index="0"
        >
          Here are some projects I've loved working on.
        </h2>
      </div>
      <ul class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          featuredProjects.map((project, index) => (
            <li class="scroll-animations-hidden" data-stagger-index={index + 1}>
              <ProjectCard
                href={`/projects/${project.id}`}
                title={project.data.title}
                description={project.data.description}
                image={project.data.image}
                color={project.data.color}
              />
            </li>
          ))
        }
      </ul>
      <LinkButton
        href="/projects"
        class="group scroll-animations-hidden gap-2 self-center"
        data-stagger-index={featuredProjects.length + 1}
      >
        See all projects
        <AnimatedArrow />
      </LinkButton>
    </section>
  </div>
  <div class="px-4">
    <section
      id="contact"
      class="scroll-mt-header mx-auto flex max-w-360 flex-col gap-16 py-16 md:pt-24 md:pb-48"
      data-animate
    >
      <h2
        class="scroll-animations-hidden text-left text-2xl font-semibold md:text-center md:text-3xl"
        data-stagger-index="0"
      >
        Have a project in mind? Let's talk about it.
      </h2>
      <div class="grid w-full gap-16 md:grid-cols-6 md:gap-4">
        <div
          class="flex flex-col gap-4 md:order-2 md:col-span-3 md:items-start lg:col-span-2 lg:pl-12"
        >
          <p
            class="scroll-animations-hidden text-muted-foreground text-lg"
            data-stagger-index={stagger({
              default: 1,
              768: contact.length + 3,
            })}
          >
            I'm open to new projects, ideas, and opportunities. If you have
            something in mind, send me a message and I'll get back to you.
          </p>
          <span
            class="scroll-animations-hidden bg-border h-px w-full"
            data-stagger-index={stagger({
              default: 2,
              768: contact.length + 4,
            })}></span>
          <ul class="flex flex-col gap-3">
            {
              contact.map(({ data }, index) => (
                <li
                  class="scroll-animations-hidden w-fit"
                  data-stagger-index={stagger({
                    default: index + 3,
                    768: index + contact.length + 5,
                  })}
                >
                  <a
                    href={data.url}
                    target="_blank"
                    class="group focus-visible:border-ring focus-visible:ring-ring/50 flex items-center gap-2 text-base font-medium outline-none focus-visible:ring-[3px]"
                  >
                    <div class="group-hover:bg-accent/50 bg-card grid size-8 place-items-center rounded-full transition-colors">
                      <Icon name={data.icon} size={16} />
                    </div>
                    <span class="bg-border h-4 w-px" />
                    <span class="text-muted-foreground group-hover:text-foreground transition-colors">
                      {data.text}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div
          class="scroll-animations-hidden bg-card rounded-[1.25rem] md:order-1 md:col-span-3 lg:col-span-2 lg:col-start-2"
          data-stagger-index={stagger({
            default: contact.length + 3,
            768: 1,
          })}
        >
          <ContactForm class="grid gap-6 p-4 md:p-6 lg:p-8">
            <FormField
              class="scroll-animations-hidden"
              data-stagger-index={stagger({
                default: contact.length + 4,
                768: 2,
              })}
            >
              <FormLabel for="name">Name</FormLabel>
              <FormInput
                type="text"
                name="name"
                id="name"
                placeholder="Jane Doe"
                required
              />
            </FormField>
            <FormField
              class="scroll-animations-hidden"
              data-stagger-index={stagger({
                default: contact.length + 5,
                768: 3,
              })}
            >
              <FormLabel for="email">Email</FormLabel>
              <FormInput
                type="email"
                name="email"
                id="email"
                placeholder="jane@example.com"
                required
              />
            </FormField>
            <FormField
              class="scroll-animations-hidden"
              data-stagger-index={stagger({
                default: contact.length + 6,
                768: 4,
              })}
            >
              <FormLabel for="message">Message</FormLabel>
              <FormTextarea
                rows={4}
                name="message"
                id="message"
                placeholder="Tell me about your project"
                required
              />
            </FormField>
            <Button
              type="submit"
              class="scroll-animations-hidden"
              data-stagger-index={stagger({
                default: contact.length + 7,
                768: 5,
              })}
            >
              <Icon name="heroicons:paper-airplane-16-solid" />
              Send message
            </Button>
          </ContactForm>
        </div>
      </div>
    </section>
  </div>
</MainLayout>
