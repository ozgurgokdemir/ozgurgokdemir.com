---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Icon from '@/components/icon.astro';
import { sortByOrder } from '@/utils/content-collections';
import heroImage from '@/assets/designtokenstudio.png';
import BlurryGradient from '@/assets/blurry-gradient.svg';
import MainLayout from '@/layouts/main-layout.astro';
import LinkButton from '@/components/link-button.astro';
import ProjectCard from '@/components/project-card.astro';
import FormField from '@/components/form-field.astro';
import FormLabel from '@/components/form-label.astro';
import FormInput from '@/components/form-input.astro';
import FormTextarea from '@/components/form-textarea.astro';
import Button from '@/components/button.astro';
import Frame from '@/components/frame.astro';
import ContactForm from '@/components/contact-form.astro';
import Technology from '@/components/technology.astro';

const featuredProjects = await getCollection(
  'projects',
  ({ data }) => data.featured,
)
  .then(sortByOrder)
  .then((projects) => projects.slice(0, 6));

const technologies = await getCollection('technologies').then(sortByOrder);

const contact = await getCollection('contact').then(sortByOrder);
---

<MainLayout
  title="Özgür Gökdemir — Frontend Developer"
  description="Özgür Gökdemir is a frontend developer specializing in building responsive and high-performance web applications using TypeScript, React, and Next.js."
>
  <div class="px-4">
    <section
      id="home"
      class="scroll-mt-header mx-auto flex max-w-[90rem] flex-col gap-16 py-16 md:gap-24 md:py-24"
      data-animate
    >
      <div class="flex flex-col gap-6 md:items-center">
        <h1
          class="scroll-animations-hidden max-w-5xl text-5xl font-semibold tracking-tight md:text-center"
          data-stagger-index="0"
        >
          I build thoughtful software products from interface to backend.
        </h1>
        <div
          class="scroll-animations-hidden mt-2 flex items-center gap-4"
          data-stagger-index="1"
        >
          <LinkButton id="contact-link" href="/#contact">
            <Icon name="heroicons:chat-bubble-left-ellipsis-16-solid" />
            Let's Talk
          </LinkButton>
          <LinkButton href="/projects" variant="outline">
            View my work
          </LinkButton>
        </div>
      </div>
      <Frame class="scroll-animations-hidden" data-stagger-index="2">
        <div
          class="relative aspect-video overflow-hidden rounded-2xl bg-cover bg-center"
        >
          <BlurryGradient class="absolute h-full w-full" />
          <Image
            src={heroImage}
            alt="featured project"
            width={1280}
            height={720}
            layout="constrained"
            priority={true}
            class="pointer-events-none absolute top-1/10 left-1/8 scale-110 skew-x-4 -skew-y-12 rounded-lg ring-[clamp(0.25rem,1vw,0.5rem)] ring-black/10 select-none md:rounded-2xl"
          />
        </div>
      </Frame>
    </section>
  </div>
  <div class="px-4">
    <section
      id="about"
      class="scroll-mt-header mx-auto flex max-w-[90rem] flex-col gap-16 py-16 md:py-24"
      data-animate
    >
      <h2
        class="scroll-animations-hidden text-3xl font-semibold"
        data-stagger-index="0"
      >
        A little about me and the tools behind my work.
      </h2>
      <div class="grid gap-16 md:grid-cols-3 md:gap-4">
        <ul
          class="grid grid-cols-1 gap-2 sm:grid-cols-2 md:col-span-2 md:auto-cols-fr md:grid-flow-col md:grid-cols-none md:grid-rows-4"
        >
          {
            technologies.map(({ data }, index) => (
              <li
                class="scroll-animations-hidden"
                data-stagger-index={index + 1}
              >
                <Technology
                  label={data.label}
                  category={data.category}
                  icon={data.icon}
                />
              </li>
            ))
          }
        </ul>
        <div
          class="text-muted-foreground scroll-animations-hidden flex flex-col items-start gap-4 text-lg font-semibold lg:pl-12"
          data-stagger-index={technologies.length + 1}
        >
          <p>
            I’m a full-stack developer focused on building thoughtful, practical
            software products. I care about the details that make an interface
            feel polished, and the systems behind it that make a product
            reliable.
          </p>
          <p>
            My work spans frontend interfaces, backend APIs, SaaS products,
            e-commerce experiences, and mobile applications. I enjoy working
            across the product, from shaping user flows and interaction details
            to designing data models, integrations, authentication, and
            deployment.
          </p>
        </div>
      </div>
    </section>
  </div>
  <div class="px-4">
    <section
      id="projects"
      class="scroll-mt-header mx-auto flex max-w-[90rem] flex-col gap-16 py-16 md:py-24"
      data-animate
    >
      <div class="flex flex-col items-start gap-4">
        <h2
          class="scroll-animations-hidden text-3xl font-semibold"
          data-stagger-index="0"
        >
          Here are some projects I've loved working on.
        </h2>
      </div>
      <ul class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {
          featuredProjects.map((project, index) => (
            <li class="scroll-animations-hidden" data-stagger-index={index + 1}>
              <ProjectCard
                href={`/projects/${project.id}`}
                title={project.data.title}
                description={project.data.description}
                image={project.data.image}
                color={project.data.color}
              />
            </li>
          ))
        }
      </ul>
      <LinkButton
        href="/projects"
        class="group scroll-animations-hidden gap-2 self-center"
        data-stagger-index={featuredProjects.length + 1}
      >
        See all projects
        <Icon
          name="heroicons:arrow-right-16-solid"
          size={16}
          class="transition-transform group-hover:translate-x-1"
        />
      </LinkButton>
    </section>
  </div>
  <div class="px-4">
    <section
      id="contact"
      class="scroll-mt-header mx-auto grid max-w-[90rem] gap-16 py-16 md:grid-cols-2 md:gap-4 md:pt-24 md:pb-48"
      data-animate
    >
      <div class="flex flex-col gap-4 md:items-start md:pt-12 lg:pr-12">
        <h2
          class="scroll-animations-hidden text-3xl font-semibold"
          data-stagger-index="0"
        >
          Get in touch.
        </h2>
        <p
          class="scroll-animations-hidden text-muted-foreground text-lg"
          data-stagger-index="1"
        >
          I'm always open to new projects, ideas, and opportunities. Please get
          in touch if you have a question or simply want to say hello, and I
          will get back to you as soon as I can.
        </p>
        <span
          class="scroll-animations-hidden bg-border h-px w-full"
          data-stagger-index="2"></span>
        <ul class="flex flex-col gap-3">
          {
            contact.map(({ data }, index) => (
              <li
                class="scroll-animations-hidden w-fit"
                data-stagger-index={index + 2}
              >
                <a
                  href={data.url}
                  target="_blank"
                  class="group focus-visible:border-ring focus-visible:ring-ring/50 flex items-center gap-2 text-base font-medium outline-none focus-visible:ring-[3px]"
                >
                  <div class="group-hover:bg-accent/50 bg-card grid size-8 place-items-center rounded-lg transition-colors">
                    <Icon name={data.icon} size={16} />
                  </div>
                  <span class="bg-border h-4 w-px" />
                  <span class="text-muted-foreground group-hover:text-foreground transition-colors">
                    {data.text}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <Frame
        class="scroll-animations-hidden"
        data-stagger-index={contact.length + 2}
      >
        <ContactForm class="grid gap-6 md:p-6 lg:p-8">
          <FormField
            class="scroll-animations-hidden"
            data-stagger-index={contact.length + 2}
          >
            <FormLabel for="name">Name</FormLabel>
            <FormInput
              type="text"
              name="name"
              id="name"
              placeholder="Jane Doe"
              required
            />
          </FormField>
          <FormField
            class="scroll-animations-hidden"
            data-stagger-index={contact.length + 3}
          >
            <FormLabel for="email">Email</FormLabel>
            <FormInput
              type="email"
              name="email"
              id="email"
              placeholder="jane@example.com"
              required
            />
          </FormField>
          <FormField
            class="scroll-animations-hidden"
            data-stagger-index={contact.length + 4}
          >
            <FormLabel for="message">Message</FormLabel>
            <FormTextarea
              rows={4}
              name="message"
              id="message"
              placeholder="Tell me about your project"
              required
            />
          </FormField>
          <Button
            type="submit"
            class="scroll-animations-hidden lg:w-fit"
            data-stagger-index={contact.length + 5}
          >
            <Icon name="heroicons:paper-airplane-16-solid" />
            Send message
          </Button>
        </ContactForm>
      </Frame>
    </section>
  </div>
</MainLayout>
