{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ozgurgokdemir",
  "compatibility_date": "2026-06-17",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "main": "@astrojs/cloudflare/entrypoints/server",
  "keep_vars": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
